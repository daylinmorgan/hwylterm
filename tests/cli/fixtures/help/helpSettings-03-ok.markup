[red]usage[/red]:
  [bold]help-settings noColor[/bold] [[flags]

show noColor help

[red]flags[/red]:
    --input [faint]string[/faint] required input (required)
    --key   [faint]string[/faint] predefined help string [faint](default: value)[/faint]
    --other        first line of help
 -h --help         print help