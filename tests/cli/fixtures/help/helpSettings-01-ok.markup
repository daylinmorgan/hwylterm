[red]usage[/red]:
  [bold]help-settings all[/bold] [[flags]

show all help styling settings

[red]flags[/red]:
 [yellow]-h[/yellow] [magenta]--help [/magenta]        print help

[red]group flags[/red]:
    [magenta]--input[/magenta] [faint]string[/faint] required input [red](required)[/red]
    [magenta]--key  [/magenta] [faint]string[/faint] predefined help string [faint](default: value)[/faint]
    [magenta]--other[/magenta]        first line of help